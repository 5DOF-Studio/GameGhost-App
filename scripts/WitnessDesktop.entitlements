<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- NOT sandboxed — required for ScreenCaptureKit and Ghost Mode NSPanel -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- Screen capture (ScreenCaptureKit TCC) -->
    <key>com.apple.security.screen-capture</key>
    <true/>

    <!-- Microphone access for voice chat -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Network access for AI API calls (Gemini, OpenAI, OpenRouter, Supabase) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Allow loading unsigned native frameworks (GaimerGhostMode, GaimerScreenCapture) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- JIT compilation (required by .NET runtime) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (required by .NET runtime on macOS) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
