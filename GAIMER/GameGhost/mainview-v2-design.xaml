<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WitnessDesktop.ViewModels"
             xmlns:models="clr-namespace:WitnessDesktop.Models"
             x:Class="WitnessDesktop.MainPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#130c1a"
             Title="Gaimer Dashboard">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Desktop-Optimized Color Palette -->
            <Color x:Key="BgPrimary">#130c1a</Color>
            <Color x:Key="BgSecondary">#1f152a</Color>
            <Color x:Key="BgCard">#1a1225</Color>
            <Color x:Key="BgCardHover">#2a1f3a</Color>
            <Color x:Key="AccentPurple">#7f13ec</Color>
            <Color x:Key="AccentPurpleDark">#5e0eb0</Color>
            <Color x:Key="AccentCyan">#ad92c9</Color>
            <Color x:Key="AccentGreen">#10b981</Color>
            <Color x:Key="AccentRed">#ef4444</Color>
            <Color x:Key="AccentYellow">#f59e0b</Color>
            <Color x:Key="TextPrimary">#ffffff</Color>
            <Color x:Key="TextSecondary">#e5e7eb</Color>
            <Color x:Key="TextMuted">#9ca3af</Color>
            <Color x:Key="BorderSubtle">#ffffff0d</Color>

            <DataTemplate x:Key="ChatMessageTemplate" x:DataType="models:ChatMessage">
                <VerticalStackLayout Spacing="4" Margin="0,0,0,16">
                    <!-- Message Header (Type + Timestamp) -->
                    <Grid ColumnDefinitions="Auto,*" Margin="4,0">
                        <HorizontalStackLayout Grid.Column="0" Spacing="8">
                            <Label Text="{Binding Type}" 
                                   FontFamily="RajdhaniSemiBold"
                                   FontSize="10"
                                   TextColor="{StaticResource AccentCyan}"
                                   CharacterSpacing="1">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="Warning">
                                        <Setter Property="TextColor" Value="{StaticResource AccentRed}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="User">
                                        <Setter Property="TextColor" Value="{StaticResource TextMuted}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                        <Label Grid.Column="1" 
                               Text="{Binding Timestamp, StringFormat='{0:HH:mm}'}"
                               FontFamily="RajdhaniRegular"
                               FontSize="10"
                               TextColor="{StaticResource TextMuted}"
                               HorizontalOptions="End"/>
                    </Grid>

                    <!-- Message Bubble -->
                    <Border BackgroundColor="{StaticResource BgCard}"
                            Stroke="{StaticResource BorderSubtle}"
                            StrokeThickness="1"
                            Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRectangle="8"/>
                        </Border.StrokeShape>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding Type}" Value="Warning">
                                <Setter Property="Stroke" Value="{StaticResource AccentRed}"/>
                                <Setter Property="StrokeThickness" Value="1"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding Type}" Value="User">
                                <Setter Property="BackgroundColor" Value="#130c1a"/>
                            </DataTrigger>
                        </Border.Triggers>

                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" 
                                       Text="⚠️" 
                                       FontSize="18" 
                                       Margin="0,0,12,0"
                                       VerticalOptions="Start"
                                       IsVisible="False">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="Warning">
                                            <Setter Property="IsVisible" Value="True"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Label Grid.Column="1"
                                       Text="{Binding Text}"
                                       FontFamily="RajdhaniSemiBold"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="16"
                                       LineBreakMode="WordWrap">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Type}" Value="User">
                                            <Setter Property="FontAttributes" Value="Italic"/>
                                            <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Grid>

                            <Image Source="{Binding ImageSource}"
                                   IsVisible="{Binding ImageSource, Converter={StaticResource IsNotNullConverter}}"
                                   Aspect="AspectFit"
                                   MaximumHeightRequest="300"
                                   HorizontalOptions="Start"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </DataTemplate>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="24" RowSpacing="24">
        
        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" 
                BackgroundColor="{StaticResource BgPrimary}"
                Padding="16,12"
                Stroke="{StaticResource BorderSubtle}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
                <!-- Logo -->
                <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                    <Label Text="⚡" 
                           TextColor="{StaticResource AccentPurple}"
                           FontSize="28"/>
                    <Label Text="GAIMER"
                           FontFamily="OrbitronBold"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="20"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
                
                <!-- Divider -->
                <BoxView Grid.Column="1" 
                         Color="{StaticResource BorderSubtle}"
                         WidthRequest="1"
                         HeightRequest="32"
                         Margin="16,0"
                         VerticalOptions="Center"/>
                
                <!-- Agent Badge -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource BgSecondary}"
                        Stroke="{StaticResource BorderSubtle}"
                        StrokeThickness="1"
                        Padding="12,6"
                        IsVisible="{Binding SelectedAgent, Converter={StaticResource IsNotNullConverter}}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🤖"
                               FontSize="16"
                               VerticalOptions="Center"/>
                        <Label Text="{Binding SelectedAgent.Name}"
                               FontFamily="RajdhaniSemiBold"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14"
                               VerticalOptions="Center"/>
                        <Border BackgroundColor="Transparent" 
                                Padding="4"
                                WidthRequest="24"
                                HeightRequest="24">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeAgentCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="↻"
                                   FontSize="14"
                                   TextColor="{StaticResource TextMuted}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </HorizontalStackLayout>
                </Border>
                
                <!-- Connection Status Badge -->
                <Border Grid.Column="3"
                        BackgroundColor="{StaticResource BgSecondary}"
                        Stroke="{StaticResource BorderSubtle}"
                        StrokeThickness="1"
                        Padding="12,6"
                        Margin="12,0,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="8">
                        <Ellipse Fill="{Binding ConnectionBadgeColor}"
                                 WidthRequest="8"
                                 HeightRequest="8"
                                 VerticalOptions="Center"/>
                        <Label Text="{Binding ConnectionBadgeText}"
                               FontFamily="RajdhaniSemiBold"
                               TextColor="{StaticResource TextMuted}"
                               FontSize="10"
                               CharacterSpacing="1"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
                
                <!-- Spacer -->
                <BoxView Grid.Column="4" Color="Transparent"/>

                <!-- Minimize Button (when connected) -->
                <Border Grid.Column="5"
                        BackgroundColor="{StaticResource BgSecondary}"
                        Stroke="{StaticResource BorderSubtle}"
                        StrokeThickness="1"
                        WidthRequest="40"
                        HeightRequest="40"
                        Margin="0,0,8,0"
                        IsVisible="{Binding IsConnected}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenMinimalViewCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="🗕"
                           FontSize="16"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                
                <!-- Settings Button -->
                <Border Grid.Column="6"
                        BackgroundColor="{StaticResource BgSecondary}"
                        Stroke="{StaticResource BorderSubtle}"
                        StrokeThickness="1"
                        WidthRequest="40"
                        HeightRequest="40">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="⚙️"
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
            </Grid>
        </Border>
        
        <!-- ========== MAIN CONTENT ========== -->
        <Grid Grid.Row="1" ColumnDefinitions="300,*" ColumnSpacing="24">
            
            <!-- LEFT SIDEBAR -->
            <VerticalStackLayout Grid.Column="0" Spacing="16">
                
                <!-- Live Preview Panel -->
                <Border BackgroundColor="{StaticResource BgCard}"
                        Stroke="{StaticResource BorderSubtle}"
                        StrokeThickness="1"
                        Padding="12">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    
                    <VerticalStackLayout Spacing="8">
                        <!-- Header -->
                        <Grid ColumnDefinitions="*,Auto">
                            <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                <Label Text="🖥️"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                                <Label Text="LIVE PREVIEW"
                                       FontFamily="OrbitronBold"
                                       TextColor="{StaticResource AccentPurple}"
                                       FontSize="10"
                                       CharacterSpacing="1"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            
                            <!-- Live Badge -->
                            <Border Grid.Column="1"
                                    BackgroundColor="#ef44441a"
                                    Stroke="#ef444433"
                                    StrokeThickness="1"
                                    Padding="6,2"
                                    IsVisible="{Binding IsConnected}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="4"/>
                                </Border.StrokeShape>
                                <HorizontalStackLayout Spacing="4">
                                    <Ellipse Fill="{StaticResource AccentRed}"
                                             WidthRequest="6"
                                             HeightRequest="6"
                                             VerticalOptions="Center"/>
                                    <Label Text="LIVE"
                                           FontFamily="RajdhaniSemiBold"
                                           FontSize="9"
                                           TextColor="{StaticResource AccentRed}"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                        
                        <!-- Preview Display -->
                        <Border BackgroundColor="#00000066"
                                Stroke="{StaticResource BorderSubtle}"
                                StrokeThickness="1"
                                HeightRequest="200">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            
                            <Grid>
                                <!-- Preview Image -->
                                <Image Source="{Binding PreviewImage, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                       Aspect="AspectFill"
                                       IsVisible="{Binding PreviewImage, Converter={StaticResource IsNotNullConverter}}"/>

                                <!-- Empty State -->
                                <VerticalStackLayout IsVisible="{Binding PreviewImage, Converter={StaticResource InvertedBoolConverter}}"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Spacing="8">
                                    <Label Text="📺"
                                           FontSize="48"
                                           HorizontalOptions="Center"
                                           Opacity="0.3"/>
                                    <Label Text="Detecting gameplay..."
                                           FontFamily="RajdhaniRegular"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="10"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                
                                <!-- Preview Overlay Info -->
                                <VerticalStackLayout IsVisible="{Binding IsConnected}"
                                                     VerticalOptions="End"
                                                     HorizontalOptions="Start"
                                                     Margin="12"
                                                     Spacing="2">
                                    <Label Text="{Binding SelectedTarget.ProcessName, FallbackValue='Unknown Game'}"
                                           FontFamily="RajdhaniSemiBold"
                                           TextColor="{StaticResource TextPrimary}"
                                           FontSize="14">
                                        <Label.Shadow>
                                            <Shadow Brush="Black" Offset="0,1" Radius="2" Opacity="0.8"/>
                                        </Label.Shadow>
                                    </Label>
                                    <Label Text="Detecting gameplay..."
                                           FontFamily="RajdhaniRegular"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="10">
                                        <Label.Shadow>
                                            <Shadow Brush="Black" Offset="0,1" Radius="2" Opacity="0.8"/>
                                        </Label.Shadow>
                                    </Label>
                                </VerticalStackLayout>

                                <!-- FPS Badge -->
                                <Border VerticalOptions="End" 
                                        HorizontalOptions="End" 
                                        Margin="12"
                                        BackgroundColor="#00000080"
                                        Padding="6,2"
                                        IsVisible="{Binding IsConnected}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4"/>
                                    </Border.StrokeShape>
                                    <Label Text="1 FPS" 
                                           TextColor="White" 
                                           FontSize="9" 
                                           FontFamily="RajdhaniSemiBold"/>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- Source Info -->
                        <Grid ColumnDefinitions="Auto,*" Margin="4,4,4,0">
                            <Label Grid.Column="0"
                                   Text="Source"
                                   FontFamily="RajdhaniRegular"
                                   TextColor="{StaticResource TextMuted}"
                                   FontSize="10"/>
                            <Label Grid.Column="1"
                                   Text="{Binding SelectedTarget.ProcessName, FallbackValue='None', StringFormat='{0}.exe'}"
                                   FontFamily="RajdhaniSemiBold"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="10"
                                   HorizontalOptions="End"
                                   LineBreakMode="TailTruncation"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
                
                <!-- Active Application Panel -->
                <Border BackgroundColor="{StaticResource BgCard}"
                        Stroke="{StaticResource BorderSubtle}"
                        StrokeThickness="1"
                        Padding="12"
                        VerticalOptions="FillAndExpand">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    
                    <Grid RowDefinitions="Auto,*">
                        <!-- Header -->
                        <HorizontalStackLayout Grid.Row="0" Spacing="8" Margin="0,0,0,12">
                            <Label Text="📱"
                                   FontSize="14"
                                   VerticalOptions="Center"/>
                            <Label Text="ACTIVE APPLICATION"
                                   FontFamily="OrbitronBold"
                                   TextColor="{StaticResource AccentPurple}"
                                   FontSize="10"
                                   CharacterSpacing="1"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        
                        <!-- App List -->
                        <ScrollView Grid.Row="1">
                            <VerticalStackLayout Spacing="8">
                                <!-- Connected App -->
                                <Border BackgroundColor="#7f13ec1a"
                                        Stroke="#7f13ec4d"
                                        StrokeThickness="1"
                                        Padding="8"
                                        IsVisible="{Binding IsConnected}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    
                                    <Grid ColumnDefinitions="32,*,Auto" ColumnSpacing="8">
                                        <Border Grid.Column="0"
                                                BackgroundColor="#00000066"
                                                Stroke="{StaticResource BorderSubtle}"
                                                StrokeThickness="1"
                                                WidthRequest="32"
                                                HeightRequest="32">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="6"/>
                                            </Border.StrokeShape>
                                            <Label Text="🎮"
                                                   FontSize="14"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                        
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding SelectedTarget.ProcessName, FallbackValue='Game'}"
                                                   FontFamily="RajdhaniSemiBold"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   FontSize="12"/>
                                            <Label Text="Connected • Running"
                                                   FontFamily="RajdhaniRegular"
                                                   TextColor="{StaticResource AccentPurple}"
                                                   FontSize="10"/>
                                        </VerticalStackLayout>
                                        
                                        <Label Grid.Column="2"
                                               Text="▼"
                                               TextColor="{StaticResource AccentPurple}"
                                               FontSize="14"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                                
                                <!-- Divider -->
                                <BoxView Color="{StaticResource BorderSubtle}"
                                         HeightRequest="1"
                                         Margin="4,4"/>
                                
                                <Label Text="CONNECTABLE APPS"
                                       FontFamily="RajdhaniSemiBold"
                                       TextColor="{StaticResource TextMuted}"
                                       FontSize="10"
                                       CharacterSpacing="1"
                                       Margin="4,0"/>
                                
                                <!-- Connectable Apps List -->
                                <CollectionView ItemsSource="{Binding CaptureTargets}"
                                                SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:CaptureTarget">
                                            <Border BackgroundColor="{StaticResource BgSecondary}"
                                                    Stroke="{StaticResource BorderSubtle}"
                                                    StrokeThickness="1"
                                                    Padding="8"
                                                    Margin="0,0,0,6">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8"/>
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer 
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=SelectTargetCommand}"
                                                        CommandParameter="{Binding}"/>
                                                </Border.GestureRecognizers>
                                                
                                                <Grid ColumnDefinitions="32,*,Auto" ColumnSpacing="8">
                                                    <Border Grid.Column="0"
                                                            BackgroundColor="#00000066"
                                                            Stroke="{StaticResource BorderSubtle}"
                                                            StrokeThickness="1"
                                                            WidthRequest="32"
                                                            HeightRequest="32">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="6"/>
                                                        </Border.StrokeShape>
                                                        <Label Text="🌐"
                                                               FontSize="14"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center"/>
                                                    </Border>
                                                    
                                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                                        <Label Text="{Binding ProcessName}"
                                                               FontFamily="RajdhaniSemiBold"
                                                               TextColor="{StaticResource TextSecondary}"
                                                               FontSize="12"/>
                                                        <Label Text="{Binding WindowTitle}"
                                                               FontFamily="RajdhaniRegular"
                                                               TextColor="{StaticResource TextMuted}"
                                                               FontSize="10"
                                                               LineBreakMode="TailTruncation"/>
                                                    </VerticalStackLayout>
                                                    
                                                    <!-- Chess Badge (Label does not reliably support Padding; wrap in Border) -->
                                                    <Border Grid.Column="2"
                                                            BackgroundColor="#f59e0b1a"
                                                            Stroke="{StaticResource BorderSubtle}"
                                                            StrokeThickness="1"
                                                            Padding="6,2"
                                                            VerticalOptions="Center"
                                                            IsVisible="{Binding ChessBadge, Converter={StaticResource IsNotNullConverter}}">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="6"/>
                                                        </Border.StrokeShape>
                                                        <Label Text="{Binding ChessBadge}"
                                                               FontFamily="RajdhaniSemiBold"
                                                               TextColor="{StaticResource AccentYellow}"
                                                               FontSize="9"
                                                               VerticalOptions="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </ScrollView>
                    </Grid>
                </Border>
                
            </VerticalStackLayout>
            
            <!-- RIGHT MAIN AREA -->
            <Border Grid.Column="1"
                    BackgroundColor="{StaticResource BgCard}"
                    Stroke="{StaticResource BorderSubtle}"
                    StrokeThickness="1"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Chat Header -->
                    <Border Grid.Row="0"
                            BackgroundColor="#1f152a80"
                            Padding="0"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16,16,0,0"/>
                        </Border.StrokeShape>

                        <!-- Simulate bottom-only divider (Border does not support per-side StrokeThickness) -->
                        <Grid RowDefinitions="Auto,1">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Padding="16,12">
                            <!-- AI Icon + Title -->
                            <HorizontalStackLayout Grid.Column="0" Spacing="12">
                                <Border BackgroundColor="{StaticResource AccentPurple}"
                                        WidthRequest="36"
                                        HeightRequest="36">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="{StaticResource AccentPurple}"
                                                Offset="0,4"
                                                Radius="12"
                                                Opacity="0.3"/>
                                    </Border.Shadow>
                                    <Label Text="🤖"
                                           FontSize="18"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="AI Companion"
                                           FontFamily="RajdhaniSemiBold"
                                           TextColor="{StaticResource TextPrimary}"
                                           FontSize="14"/>
                                    <Label Text="Session Active • Monitoring"
                                           FontFamily="RajdhaniRegular"
                                           TextColor="{StaticResource AccentCyan}"
                                           FontSize="10"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                            
                            <BoxView Grid.Column="1" Color="Transparent"/>
                            
                            <!-- History Button -->
                            <Border Grid.Column="2"
                                    BackgroundColor="Transparent"
                                    WidthRequest="32"
                                    HeightRequest="32"
                                    Margin="0,0,8,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="🕐"
                                       FontSize="18"
                                       TextColor="{StaticResource TextMuted}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            
                            <!-- Clear Button -->
                            <Border Grid.Column="3"
                                    BackgroundColor="Transparent"
                                    WidthRequest="32"
                                    HeightRequest="32">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ClearChatCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="🗑️"
                                       FontSize="18"
                                       TextColor="{StaticResource TextMuted}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                        <BoxView Grid.Row="1"
                                 Color="{StaticResource BorderSubtle}"
                                 HeightRequest="1"
                                 HorizontalOptions="Fill"/>
                        </Grid>
                    </Border>
                    
                    <!-- Chat Messages Area -->
                    <CollectionView Grid.Row="1" 
                                    ItemsSource="{Binding ChatMessages}"
                                    ItemTemplate="{StaticResource ChatMessageTemplate}"
                                    ItemsUpdatingScrollMode="KeepLastItem"
                                    Padding="24">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="8">
                                <Label Text="Nothing new to display"
                                       FontFamily="RajdhaniRegular"
                                       TextColor="{StaticResource TextMuted}"
                                       FontSize="16"
                                       HorizontalOptions="Center"/>
                                <Label Text="AI insights will appear here during gameplay"
                                       FontFamily="RajdhaniRegular"
                                       TextColor="{StaticResource TextMuted}"
                                       FontSize="13"
                                       HorizontalOptions="Center"
                                       Opacity="0.7"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>

                    <!-- Chat Input Bar -->
                    <Border Grid.Row="2"
                            BackgroundColor="#1f152a80"
                            Padding="16,12"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0,0,16,16"/>
                        </Border.StrokeShape>
                        
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource BgPrimary}"
                                    Stroke="{StaticResource BorderSubtle}"
                                    StrokeThickness="1"
                                    Padding="12,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding MessageDraftText}"
                                       Placeholder="Ask Gaimer..."
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontFamily="RajdhaniRegular"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center">
                                    <Entry.Keyboard>
                                        <Keyboard x:FactoryMethod="Create">
                                            <x:Arguments>
                                                <KeyboardFlags>Suggestions,CapitalizeSentences</KeyboardFlags>
                                            </x:Arguments>
                                        </Keyboard>
                                    </Entry.Keyboard>
                                </Entry>
                            </Border>

                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource AccentPurple}"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    Padding="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SendTextMessageCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="✈️"
                                       FontSize="18"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TranslationX="-1"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        
        <!-- ========== BOTTOM BAR (AUDIO + CONNECT) ========== -->
        <Border Grid.Row="2" Grid.RowSpan="2"
                BackgroundColor="{StaticResource BgPrimary}"
                Padding="16,12"
                Stroke="{StaticResource BorderSubtle}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <!-- Audio Section -->
                <HorizontalStackLayout Grid.Column="0" Spacing="16" VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🎤" FontSize="16" VerticalOptions="Center"/>
                        <Label Text="AUDIO"
                               FontFamily="OrbitronBold"
                               TextColor="{StaticResource AccentPurple}"
                               FontSize="10"
                               CharacterSpacing="1"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    
                    <HorizontalStackLayout Spacing="12">
                        <Label FontFamily="RajdhaniSemiBold" TextColor="{StaticResource TextSecondary}" FontSize="12">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="IN: " TextColor="{StaticResource TextMuted}"/>
                                    <Span Text="{Binding InputVolume, StringFormat='{0:P0}'}"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label FontFamily="RajdhaniSemiBold" TextColor="{StaticResource TextSecondary}" FontSize="12">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="OUT: " TextColor="{StaticResource TextMuted}"/>
                                    <Span Text="{Binding OutputVolume, StringFormat='{0:P0}'}"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </HorizontalStackLayout>

                    <!-- Audio Visualizer Bars -->
                    <HorizontalStackLayout Spacing="3" VerticalOptions="Center" Margin="12,0,0,0">
                        <BoxView WidthRequest="4" HeightRequest="{Binding ActivityVolume, Converter={StaticResource AudioBarHeightConverter}, ConverterParameter=0}" Color="{StaticResource AccentPurple}" CornerRadius="2" VerticalOptions="Center"/>
                        <BoxView WidthRequest="4" HeightRequest="{Binding ActivityVolume, Converter={StaticResource AudioBarHeightConverter}, ConverterParameter=1}" Color="{StaticResource AccentPurple}" CornerRadius="2" VerticalOptions="Center"/>
                        <BoxView WidthRequest="4" HeightRequest="{Binding ActivityVolume, Converter={StaticResource AudioBarHeightConverter}, ConverterParameter=2}" Color="{StaticResource AccentPurple}" CornerRadius="2" VerticalOptions="Center"/>
                        <BoxView WidthRequest="4" HeightRequest="{Binding ActivityVolume, Converter={StaticResource AudioBarHeightConverter}, ConverterParameter=3}" Color="{StaticResource AccentPurple}" CornerRadius="2" VerticalOptions="Center"/>
                        <BoxView WidthRequest="4" HeightRequest="{Binding ActivityVolume, Converter={StaticResource AudioBarHeightConverter}, ConverterParameter=4}" Color="{StaticResource AccentPurple}" CornerRadius="2" VerticalOptions="Center"/>
                        <BoxView WidthRequest="4" HeightRequest="{Binding ActivityVolume, Converter={StaticResource AudioBarHeightConverter}, ConverterParameter=5}" Color="{StaticResource AccentPurple}" CornerRadius="2" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>

                <!-- Footer Info -->
                <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="{Binding SelectedAgent.Name, FallbackValue='No Agent'}"
                           FontFamily="RajdhaniSemiBold"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="12"/>
                    <Label Text="|" TextColor="{StaticResource TextMuted}" FontSize="12"/>
                    <Label Text="{Binding GeminiBackendText}"
                           FontFamily="RajdhaniRegular"
                           TextColor="{StaticResource TextMuted}"
                           FontSize="12"/>
                </HorizontalStackLayout>
                
                <!-- Connect Button -->
                <Border Grid.Column="2"
                        WidthRequest="140"
                        HeightRequest="40"
                        Padding="0"
                        Stroke="{StaticResource BorderSubtle}"
                        StrokeThickness="1"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsConnected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource AccentRed}"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsConnected}" Value="False">
                            <Setter Property="BackgroundColor" Value="{StaticResource AccentPurple}"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding CanConnect}" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleConnectionCommand}"/>
                    </Border.GestureRecognizers>
                    
                    <Grid HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="{Binding ConnectButtonText}"
                               FontFamily="RajdhaniSemiBold"
                               FontSize="13"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               IsVisible="{Binding IsConnecting, Converter={StaticResource InvertedBoolConverter}}"/>
                        
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding IsConnecting}">
                            <ActivityIndicator IsRunning="{Binding IsConnecting}"
                                               Color="White"
                                               WidthRequest="14"
                                               HeightRequest="14"/>
                            <Label Text="..."
                                   FontFamily="RajdhaniSemiBold"
                                   FontSize="13"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
        
    </Grid>
</ContentPage>

