<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:GaimerDesktop.Controls"
             xmlns:vm="clr-namespace:GaimerDesktop.ViewModels"
             x:Class="GaimerDesktop.Views.AudioControlPanelView"
             x:DataType="vm:MainViewModel">

    <!-- Four toggle switches -->
    <HorizontalStackLayout Spacing="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">

            <!-- VOICE CHAT Switch -->
            <VerticalStackLayout Spacing="4"
                                 HorizontalOptions="Center">
                <controls:IndustrialToggleSwitch
                    IsToggled="{Binding IsVoiceChatActive}"
                    LedOnColor="#22c55e"
                    LedOffColor="#1a2a1e"/>
                <Label Text="VOICE CHAT"
                       FontFamily="RajdhaniSemiBold"
                       FontSize="12"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- VOICE COMMAND Switch -->
            <VerticalStackLayout Spacing="4"
                                 HorizontalOptions="Center">
                <controls:IndustrialToggleSwitch
                    IsToggled="{Binding IsAiMicActive}"
                    LedOnColor="#4ea3ff"
                    LedOffColor="#15202a"/>
                <Label Text="VOICE COMMAND"
                       FontFamily="RajdhaniSemiBold"
                       FontSize="12"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- GAME AUDIO Switch -->
            <VerticalStackLayout Spacing="4"
                                 HorizontalOptions="Center">
                <controls:IndustrialToggleSwitch
                    IsToggled="{Binding IsCommentaryActive}"
                    LedOnColor="#f2a900"
                    LedOffColor="#2a2215"/>
                <Label Text="GAME AUDIO"
                       FontFamily="RajdhaniSemiBold"
                       FontSize="12"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- AUDIO IN Switch -->
            <VerticalStackLayout Spacing="4"
                                 HorizontalOptions="Center">
                <controls:IndustrialToggleSwitch
                    IsToggled="{Binding IsAudioInActive}"
                    LedOnColor="#e11d48"
                    LedOffColor="#2a151a"/>
                <Label Text="AUDIO IN"
                       FontFamily="RajdhaniSemiBold"
                       FontSize="12"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
    </HorizontalStackLayout>
</ContentView>
