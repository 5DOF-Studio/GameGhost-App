<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GaimerDesktop.Controls.IndustrialToggleSwitch"
             WidthRequest="44"
             HeightRequest="96">

    <!-- LED Bar + Housing -->
    <Grid RowDefinitions="16,*" RowSpacing="4">

        <!-- Row 0: LED Bar -->
        <Border x:Name="LedBar"
                Grid.Row="0"
                WidthRequest="24"
                HeightRequest="6"
                BackgroundColor="#3d1515"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="3"/>
            </Border.StrokeShape>
            <Border.Stroke>
                <SolidColorBrush Color="Transparent"/>
            </Border.Stroke>
            <Border.Shadow>
                <Shadow x:Name="LedGlow"
                        Brush="Transparent"
                        Offset="0,0"
                        Radius="0"
                        Opacity="0"/>
            </Border.Shadow>
        </Border>

        <!-- Row 1: Switch Housing -->
        <Border Grid.Row="1"
                BackgroundColor="#1a1d21"
                Padding="5,6"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="38"
                HeightRequest="72">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <Border.Stroke>
                <SolidColorBrush Color="#2a2d32"/>
            </Border.Stroke>

            <!-- Rail (inset track) -->
            <Border BackgroundColor="#0e1117"
                    Padding="1,2"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="28"
                    HeightRequest="60">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6"/>
                </Border.StrokeShape>
                <Border.Stroke>
                    <SolidColorBrush Color="#1a1d21"/>
                </Border.Stroke>

                <!-- Handle Container (positions handle via TranslationY) -->
                <Grid>
                    <Border x:Name="Handle"
                            WidthRequest="26"
                            HeightRequest="28"
                            VerticalOptions="Start"
                            HorizontalOptions="Center"
                            TranslationY="28">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="5"/>
                        </Border.StrokeShape>
                        <Border.Stroke>
                            <SolidColorBrush Color="#4a4a58"/>
                        </Border.Stroke>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#8a8a98" Offset="0.0"/>
                                <GradientStop Color="#5a5a68" Offset="0.3"/>
                                <GradientStop Color="#4a4a58" Offset="0.7"/>
                                <GradientStop Color="#3a3a48" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <!-- Grip Lines -->
                        <VerticalStackLayout Spacing="3"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center">
                            <BoxView WidthRequest="14" HeightRequest="1.5"
                                     Color="#6a6a78"
                                     HorizontalOptions="Center"/>
                            <BoxView WidthRequest="14" HeightRequest="1.5"
                                     Color="#6a6a78"
                                     HorizontalOptions="Center"/>
                            <BoxView WidthRequest="14" HeightRequest="1.5"
                                     Color="#6a6a78"
                                     HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</ContentView>
